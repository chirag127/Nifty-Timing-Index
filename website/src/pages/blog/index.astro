---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const blogs = await getCollection("blog");
const sorted = blogs.sort((a: any, b: any) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

function getZoneColor(z: string): string {
  const m: Record<string,string> = {
    EXTREME_BUY:"#00ff88", STRONG_BUY:"#22c55e", BUY_LEAN:"#4ade80",
    NEUTRAL:"#60a5fa", SELL_LEAN:"#fb923c", STRONG_SELL:"#ef4444", EXTREME_SELL:"#dc2626"
  };
  return m[z] || "#64748b";
}
---

<Layout title="NTI Blog — Market Analysis & Updates" description="Hourly Indian market insights generated automatically by AI">
  <div class="blog-page">
    <header class="blog-page-header animate-fade-in-up">
      <h1>NTI Blog</h1>
      <p>Hourly insights generated automatically by AI</p>
    </header>

    {sorted.length === 0 ? (
      <div class="empty-state card animate-stagger-in stagger-1">
        <div class="empty-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
        </div>
        <p>No blog posts yet. The first post will appear after the hourly pipeline runs.</p>
        <p class="hint">Blogs are generated every hour during market hours and every 2 hours overnight.</p>
      </div>
    ) : (
      <div class="blog-grid">
        {sorted.map((post: any, i: number) => (
          <a href={`/blog/${post.data.slug}`} class="blog-card card card-hover" style={`animation-delay: ${i * 0.05}s`}>
            <div class="blog-card-header">
              <span class="blog-card-score mono" style={`color: ${getZoneColor(post.data.ntiZone)}`}>
                {post.data.ntiScore}
              </span>
              <div class="blog-card-zone-wrap">
                <span class="blog-card-zone" style={`color: ${getZoneColor(post.data.ntiZone)}`}>
                  {post.data.ntiZone?.replace(/_/g, " ")}
                </span>
                {post.data.zoneChanged && (
                  <span class="badge badge-crimson">Zone Changed</span>
                )}
              </div>
            </div>
            <h3 class="blog-card-title">{post.data.title}</h3>
            <time class="blog-card-date">
              {new Date(post.data.publishedAt).toLocaleDateString("en-IN", {
                day: "numeric", month: "short", year: "numeric",
                hour: "2-digit", minute: "2-digit"
              })} IST
            </time>
            <span class="badge badge-gold blog-type-badge">{post.data.blogType?.replace(/_/g, " ")}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>

<style>
  .blog-page { max-width: 1200px; margin: 0 auto; }
  .blog-page-header { margin-bottom: 2.5rem; }
  .blog-page-header h1 {
    font-family: var(--font-display);
    font-size: 1.85rem; font-weight: 800; color: var(--color-gold);
    letter-spacing: -0.01em;
  }
  .blog-page-header p { color: var(--color-text-muted); margin-top: 0.5rem; }

  .empty-state {
    text-align: center; padding: 4rem 2rem; color: var(--color-text-muted);
  }
  .empty-icon { opacity: 0.3; margin-bottom: 1rem; }
  .hint { font-size: 0.82rem; margin-top: 0.75rem; }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1rem;
  }

  .blog-card {
    text-decoration: none;
    color: inherit;
    padding: 1.35rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    animation: stagger-in 0.45s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  .blog-card-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .blog-card-score {
    font-size: 1.85rem;
    font-weight: 800;
    line-height: 1;
  }

  .blog-card-zone-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 0.15rem;
  }

  .blog-card-zone {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: capitalize;
  }

  .blog-card-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text-primary);
  }

  .blog-card-date {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .blog-type-badge {
    width: fit-content;
    text-transform: capitalize;
  }

  /* ---- Light Theme ---- */
  [data-theme="light"] .empty-state {
    background: var(--color-bg-sunken);
  }

  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
    .blog-page-header { margin-bottom: 1.75rem; }
    .blog-card { padding: 1.15rem; }
    .blog-card-score { font-size: 1.5rem; }
    .empty-state { padding: 3rem 1.5rem; }
  }

  /* ---- Small ---- */
  @media (max-width: 480px) {
    .blog-card { padding: 1rem; }
    .blog-card-score { font-size: 1.25rem; }
    .blog-card-title { font-size: 0.88rem; }
    .blog-card-header { gap: 0.5rem; }
    .blog-card-zone { font-size: 0.65rem; }
    .blog-card-date { font-size: 0.72rem; }
    .empty-state { padding: 2.5rem 1rem; }
    .empty-icon svg { width: 28px; height: 28px; }
  }
</style>
