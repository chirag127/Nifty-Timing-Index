# ============================================================
# NIFTY TIMING INDEX — Complete Environment Configuration
# ============================================================
# 1. Copy this file to .env
# 2. Fill in values for providers you want to use (at least one per category)
# 3. Run: python scripts/setup.py
# Everything else is automatic after that.
# NEVER commit .env to git (it's in .gitignore)
# ============================================================
# PHILOSOPHY: Every provider has an ENABLE toggle.
# The system tries providers in order, falling back to the next if one fails.
# You only need ONE provider per category to run the system.
# ============================================================

# === GitHub ===
GITHUB_USERNAME=chirag127
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_REPO_NAME=nifty-timing-index

# ============================================================
# LLM API PROVIDERS — FUSION OF MODELS (LangGraph)
# ============================================================
# The system uses LangGraph to orchestrate multi-model fusion:
#   1. Multiple LLMs generate blog drafts in parallel (fan-out)
#   2. Models critique each other's outputs
#   3. The most powerful available model synthesizes the final blog post (fan-in)
#
# Enable each provider you have a key for. The system calls ALL enabled
# providers in parallel and then fuses their outputs.
#
# ─── MULTI-MODEL SUPPORT ───
# Each provider's LLM_<PROVIDER>_MODEL variable supports BOTH single and comma-separated models:
#
#   Single model:
#     LLM_GROQ_MODEL=llama-3.3-70b-versatile
#
#   Multiple models (comma-separated — each model gets its own fusion draft):
#     LLM_GROQ_MODEL=llama-3.3-70b-versatile,mixtral-8x7b-32768,llama-3.1-8b-instant
#
# When comma-separated, each model becomes its own entry in the fusion workflow,
# generating its own draft independently. This means you get MORE diverse
# perspectives even from a single provider.
#
# Example: LLM_GROQ_MODEL=llama-3.3-70b-versatile,mixtral-8x7b-32768
# creates TWO fusion entries: "groq/llama-3.3-70b-versatile" and "groq/mixtral-8x7b-32768"
# Each gets its own parallel draft generation call.
#
# ─── FUSION SYNTHESIZER ───
# FUSION_MODE: "all" = call all enabled LLMs, "sequential" = try in order with fallback
# FUSION_SYNTHESIZER: Which provider to use as the final synthesizer
#   Can be a provider name (e.g., "groq") or a compound name (e.g., "groq/llama-3.3-70b-versatile")
# FUSION_SYNTHESIZER_MODEL: Override the synthesizer's model without changing provider
#   Example: FUSION_SYNTHESIZER=groq FUSION_SYNTHESIZER_MODEL=llama-3.3-70b-versatile
# ============================================================

FUSION_MODE=all
FUSION_SYNTHESIZER=groq
FUSION_SYNTHESIZER_MODEL=

# --- Provider 1: Groq (FREE — 1,000 req/day, ultra-fast, RECOMMENDED) ---
# Get your key: https://console.groq.com/keys
LLM_GROQ_ENABLED=true
LLM_GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_GROQ_BASE_URL=https://api.groq.com/openai/v1
# Single:  LLM_GROQ_MODEL=llama-3.3-70b-versatile
# Multi:   LLM_GROQ_MODEL=llama-3.3-70b-versatile,mixtral-8x7b-32768,llama-3.1-8b-instant
LLM_GROQ_MODEL=llama-3.3-70b-versatile
LLM_GROQ_MAX_TOKENS=2000

# --- Provider 2: Google Gemini (FREE — 15 RPM, large context) ---
# Get your key: https://aistudio.google.com/apikey
LLM_GEMINI_ENABLED=true
LLM_GEMINI_API_KEY=AIza_your_gemini_api_key_here
LLM_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Single:  LLM_GEMINI_MODEL=gemini-2.0-flash
# Multi:   LLM_GEMINI_MODEL=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-1.5-flash
LLM_GEMINI_MODEL=gemini-2.0-flash
LLM_GEMINI_MAX_TOKENS=2000

# --- Provider 3: Cerebras (FREE — 1M tokens/day, ultra-fast) ---
# Get your key: https://cloud.cerebras.ai/
LLM_CEREBRAS_ENABLED=true
LLM_CEREBRAS_API_KEY=csk_your_cerebras_api_key_here
LLM_CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# Single:  LLM_CEREBRAS_MODEL=llama-3.3-70b
# Multi:   LLM_CEREBRAS_MODEL=llama-3.3-70b,llama-3.1-8b
LLM_CEREBRAS_MODEL=llama-3.3-70b
LLM_CEREBRAS_MAX_TOKENS=2000

# --- Provider 4: OpenRouter (FREE models available — 50 req/day) ---
# Get your key: https://openrouter.ai/keys
LLM_OPENROUTER_ENABLED=true
LLM_OPENROUTER_API_KEY=sk-or-your_openrouter_key_here
LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Single:  LLM_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Multi:   LLM_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,qwen/qwen-2.5-7b-instruct:free
LLM_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_OPENROUTER_MAX_TOKENS=2000

# --- Provider 5: Together AI (FREE credits available) ---
LLM_TOGETHER_ENABLED=false
LLM_TOGETHER_API_KEY=your_together_api_key_here
LLM_TOGETHER_BASE_URL=https://api.together.xyz/v1
# Single:  LLM_TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf
# Multi:   LLM_TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf,mistralai/Mixtral-8x7B-Instruct-v0.1
LLM_TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf
LLM_TOGETHER_MAX_TOKENS=2000

# --- Provider 6: Nvidia NIM (FREE tier available) ---
# Get your key: https://build.nvidia.com/
LLM_NVIDIA_ENABLED=false
LLM_NVIDIA_API_KEY=nvapi-your_nvidia_key_here
LLM_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Single:  LLM_NVIDIA_MODEL=meta/llama-3.1-405b-instruct
# Multi:   LLM_NVIDIA_MODEL=meta/llama-3.1-405b-instruct,nvidia/llama-3.1-nemotron-70b-instruct
LLM_NVIDIA_MODEL=meta/llama-3.1-405b-instruct
LLM_NVIDIA_MAX_TOKENS=2000

# --- Provider 7: SambaNova (FREE tier available) ---
LLM_SAMBANOVA_ENABLED=false
LLM_SAMBANOVA_API_KEY=your_sambanova_api_key_here
LLM_SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
# Single:  LLM_SAMBANOVA_MODEL=Meta-Llama-3.1-70B-Instruct
# Multi:   LLM_SAMBANOVA_MODEL=Meta-Llama-3.1-70B-Instruct,Meta-Llama-3.1-8B-Instruct
LLM_SAMBANOVA_MODEL=Meta-Llama-3.1-70B-Instruct
LLM_SAMBANOVA_MAX_TOKENS=2000

# --- Provider 8: Mistral AI (FREE tier — OpenAI-compatible, European) ---
# Get your key: https://console.mistral.ai/api-keys/
LLM_MISTRAL_ENABLED=false
LLM_MISTRAL_API_KEY=your_mistral_api_key_here
LLM_MISTRAL_BASE_URL=https://api.mistral.ai/v1
# Single:  LLM_MISTRAL_MODEL=mistral-large-latest
# Multi:   LLM_MISTRAL_MODEL=mistral-large-latest,open-mistral-nemo,mistral-small-latest
LLM_MISTRAL_MODEL=mistral-large-latest
LLM_MISTRAL_MAX_TOKENS=2000

# --- Provider 9: Cohere (FREE tier — uses native Cohere SDK) ---
# Get your key: https://dashboard.cohere.com/api-keys
# NOTE: Cohere uses its own native SDK (langchain-cohere) for best results.
# If langchain-cohere is not installed, it falls back to OpenAI-compatible endpoint.
LLM_COHERE_ENABLED=false
LLM_COHERE_API_KEY=your_cohere_api_key_here
LLM_COHERE_BASE_URL=https://api.cohere.com/v2
# Single:  LLM_COHERE_MODEL=command-r-plus
# Multi:   LLM_COHERE_MODEL=command-r-plus,command-r
LLM_COHERE_MODEL=command-r-plus
LLM_COHERE_MAX_TOKENS=2000

# --- Provider 10: HuggingFace Inference API (FREE tier — uses HF SDK) ---
# Get your key: https://huggingface.co/settings/tokens
# NOTE: HuggingFace uses its own SDK (langchain-huggingface) for best results.
# Model names are in org/model format (e.g., meta-llama/Meta-Llama-3-8B-Instruct).
# If langchain-huggingface is not installed, it falls back to OpenAI-compatible endpoint.
LLM_HUGGINGFACE_ENABLED=false
LLM_HUGGINGFACE_API_KEY=hf_your_huggingface_token_here
LLM_HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co/v1
# Single:  LLM_HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
# Multi:   LLM_HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct,mistralai/Mistral-7B-Instruct-v0.3,Qwen/Qwen2.5-7B-Instruct
LLM_HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
LLM_HUGGINGFACE_MAX_TOKENS=2000

# --- Provider 11: Cloudflare Workers AI (FREE — 10k neurons/day) ---
LLM_CLOUDFLARE_ENABLED=false
LLM_CLOUDFLARE_API_KEY=your_cf_api_token_here
LLM_CLOUDFLARE_BASE_URL=https://api.cloudflare.com/client/v4/accounts/your_account_id/ai/v1
LLM_CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct
LLM_CLOUDFLARE_MAX_TOKENS=2000

# --- Legacy single-provider fallback (if no fusion providers enabled) ---
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_MAX_TOKENS=2000

# ============================================================
# SEARCH API PROVIDERS (6+ Free Search APIs)
# ============================================================
# The system uses these for web search when gathering market context.
# Enable each provider you have a key for. Tries in order, falls back to next.
# ============================================================

# --- Search Provider 1: Serper.dev (FREE — 2,500 queries, no CC) ---
SEARCH_SERPER_ENABLED=true
SEARCH_SERPER_API_KEY=your_serper_api_key_here
SEARCH_SERPER_BASE_URL=https://google.serper.dev

# --- Search Provider 2: Google Custom Search (FREE — 100 queries/day) ---
SEARCH_GOOGLE_CSE_ENABLED=false
SEARCH_GOOGLE_CSE_API_KEY=your_google_api_key_here
SEARCH_GOOGLE_CSE_CX=your_custom_search_engine_id_here
SEARCH_GOOGLE_CSE_BASE_URL=https://www.googleapis.com/customsearch/v1

# --- Search Provider 3: Tavily (FREE tier available) ---
SEARCH_TAVILY_ENABLED=false
SEARCH_TAVILY_API_KEY=tvly_your_tavily_key_here
SEARCH_TAVILY_BASE_URL=https://api.tavily.com

# --- Search Provider 4: Brave Search API (FREE — 2,000 queries/month) ---
SEARCH_BRAVE_ENABLED=false
SEARCH_BRAVE_API_KEY=your_brave_api_key_here
SEARCH_BRAVE_BASE_URL=https://api.search.brave.com

# --- Search Provider 5: DuckDuckGo (FREE — no key needed) ---
SEARCH_DUCKDUCKGO_ENABLED=true
SEARCH_DUCKDUCKGO_BASE_URL=https://api.duckduckgo.com

# --- Search Provider 6: SearXNG (FREE — self-hosted or public instances) ---
SEARCH_SEARXNG_ENABLED=false
SEARCH_SEARXNG_BASE_URL=https://searxng.example.com

# ============================================================
# NEWS API PROVIDERS (6+ Free News APIs)
# ============================================================
# The system uses these for fetching market news headlines.
# RSS feeds are always enabled (no key needed). Additional APIs enrich coverage.
# ============================================================

# --- RSS Feeds (ALWAYS FREE, no key needed) ---
NEWS_RSS_ENABLED=true
NEWS_RSS_FEEDS=economictimes,moneycontrol,businessstandard,livemint,thehindu

# --- News Provider 1: NewsAPI.org (FREE — 200 req/day, no CC) ---
NEWS_NEWSAPI_ENABLED=false
NEWS_NEWSAPI_API_KEY=your_newsapi_key_here
NEWS_NEWSAPI_BASE_URL=https://newsapi.org/v2

# --- News Provider 2: GNews API (FREE — 100 req/day) ---
NEWS_GNEWS_ENABLED=false
NEWS_GNEWS_API_KEY=your_gnews_key_here
NEWS_GNEWS_BASE_URL=https://gnews.io/api/v4

# --- News Provider 3: CurrentsAPI (FREE — 200 req/day) ---
NEWS_CURRENTS_ENABLED=false
NEWS_CURRENTS_API_KEY=your_currentsapi_key_here
NEWS_CURRENTS_BASE_URL=https://api.currentsapi.services/v1

# --- News Provider 4: MediaStack (FREE — 100 req/month) ---
NEWS_MEDIASTACK_ENABLED=false
NEWS_MEDIASTACK_API_KEY=your_mediastack_key_here
NEWS_MEDIASTACK_BASE_URL=http://api.mediastack.com/v1

# --- News Provider 5: TheNewsAPI (FREE tier available) ---
NEWS_THENEWSAPI_ENABLED=false
NEWS_THENEWSAPI_API_KEY=your_thenewsapi_key_here
NEWS_THENEWSAPI_BASE_URL=https://api.thenewsapi.com/v1

# --- News Provider 6: World News API (FREE — 50 points/day) ---
NEWS_WORLDNEWS_ENABLED=false
NEWS_WORLDNEWS_API_KEY=your_worldnews_key_here
NEWS_WORLDNEWS_BASE_URL=https://worldnewsapi.com/api/v1

# ============================================================
# EMAIL PROVIDERS (4+ with fallback)
# ============================================================
# The system sends alerts on zone changes and big moves.
# Enable each provider. Tries in order, falls back to next.
# ============================================================

# --- Email Provider 1: Gmail SMTP (FREE — 500 emails/day) ---
EMAIL_GMAIL_ENABLED=true
EMAIL_GMAIL_ADDRESS=whyiswhen@gmail.com
EMAIL_GMAIL_APP_PASSWORD=your_16_char_google_app_password_here
EMAIL_GMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_GMAIL_SMTP_PORT=587

# --- Email Provider 2: Resend (FREE — 100 emails/day, API-based) ---
EMAIL_RESEND_ENABLED=false
EMAIL_RESEND_API_KEY=re_your_resend_key_here
EMAIL_RESEND_BASE_URL=https://api.resend.com
EMAIL_RESEND_FROM=nti@yourdomain.com

# --- Email Provider 3: Brevo/Sendinblue (FREE — 300 emails/day) ---
EMAIL_BREVO_ENABLED=false
EMAIL_BREVO_API_KEY=your_brevo_key_here
EMAIL_BREVO_BASE_URL=https://api.brevo.com/v3
EMAIL_BREVO_FROM=nti@yourdomain.com

# --- Email Provider 4: SendGrid (FREE — 100 emails/day) ---
EMAIL_SENDGRID_ENABLED=false
EMAIL_SENDGRID_API_KEY=SG.your_sendgrid_key_here
EMAIL_SENDGRID_BASE_URL=https://api.sendgrid.com/v3
EMAIL_SENDGRID_FROM=nti@yourdomain.com

# --- Common Email Settings ---
ALERT_EMAIL_TO=whyiswhen@gmail.com
ALERT_ON_ZONE_CHANGE=true
ALERT_ON_BIG_MOVE=true
ALERT_BIG_MOVE_THRESHOLD=10

# ============================================================
# DATA APIs (Free Market Data)
# ============================================================

# FRED API (US 10Y yield, free — https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Finnhub (Analyst ratings, free — 60 calls/min at https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_free_api_key_here

# ============================================================
# CLOUDFLARE CONFIGURATION (For Proxy & Workers AI Deployment)
# ============================================================
# Account ID: https://dash.cloudflare.com/ (URL contains the ID)
# API Token: https://dash.cloudflare.com/profile/api-tokens (Edit Cloudflare Workers template)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_EMAIL=your_cloudflare_email_here

# CLOUDFLARE_GLOBAL_API_KEY: Cloudflare Global API Key (for DNS management & full API access)
#   1. Go to https://dash.cloudflare.com/profile/api-tokens
#   2. Scroll to "Global API Key" section and click "View"
#   3. Enter your password and copy the key
CLOUDFLARE_GLOBAL_API_KEY=your_cloudflare_global_api_key_here

# CLOUDFLARE_ORIGIN_CA_KEY: Cloudflare Origin CA Key (for SSL/TLS certificate management)
#   1. Go to https://dash.cloudflare.com/ssl-tls/origin
#   2. Used for creating and managing Origin CA certificates
#   3. Required for custom domain SSL setup
CLOUDFLARE_ORIGIN_CA_KEY=your_cloudflare_origin_ca_key_here

# ============================================================
# LANGFUSE OBSERVABILITY (Optional — LLM Call Tracing & Monitoring)
# ============================================================
# Obtain these from your Langfuse project settings: https://cloud.langfuse.com
# Enables tracing of all LLM fusion workflow calls for debugging & cost tracking.
# When enabled, every draft generation, critique, and synthesis call is traced.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ============================================================
# GIFT NIFTY (Pre-Market Indicator — formerly SGX Nifty)
# ============================================================
# GIFT Nifty provides pre-market signals before NSE India opens.
# Data is scraped from Moneycontrol & Economic Times (no API needed).
# Set to false to disable GIFT Nifty scraping.
GIFT_NIFTY_ENABLED=true

# ============================================================
# MARKET MOOD INDEX — Alternative Sources
# ============================================================
# Primary source: Tickertape MMI (Selenium scraper, always tried first)
# Alternative sources (used if Tickertape fails):
#   - RapidAPI MMI: https://rapidapi.com/ (search "Market Mood Index")
#   - Smallcase MMI: free, no key needed (may require auth in future)
MMI_RAPIDAPI_KEY=

# ============================================================
# SPACESHIP CONFIGURATION (Domain Registrar & DNS)
# ============================================================
# Spaceship.com API credentials for managing custom domain DNS
# Used for DNS record management for nti.oriz.in custom domain

# SPACESHIP_API_KEY: Spaceship API key
#   1. Go to https://spaceship.dev/api-keys and sign in
#   2. Create a new API key with DNS management permissions
#   3. Copy the key and paste below
SPACESHIP_API_KEY=your_spaceship_api_key_here

# SPACESHIP_API_SECRET: Spaceship API secret
#   1. In the same API keys page, copy the secret for your key
#   2. Keep this secret secure — it provides full API access
#   3. Paste the secret below
SPACESHIP_API_SECRET=your_spaceship_api_secret_here

# SPACESHIP_API_URL: Spaceship API endpoint
#   1. Default is https://spaceship.dev/api/v1
#   2. Only change if using a different API version
#   3. Standard Spaceship API v1 URL
SPACESHIP_API_URL=https://spaceship.dev/api/v1

# ============================================================
# FIREBASE
# ============================================================
FIREBASE_PROJECT_ID=nifty-timing-index
FIREBASE_API_KEY=AIza_your_firebase_web_api_key_here
FIREBASE_AUTH_DOMAIN=nifty-timing-index.firebaseapp.com
FIREBASE_APP_ID=1:123456789:web:abcdef
FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json_here

# ============================================================
# NTI CONFIGURATION (Feature Toggles & Limits)
# ============================================================

# Feature toggles — set to false to disable that subsystem
NTI_ENABLE_EMAIL=true
NTI_ENABLE_LLM=true
NTI_ENABLE_SCREENER=true
NTI_ENABLE_MODEL=true
NTI_ENABLE_SEARCH=true
NTI_ENABLE_NEWS=true
NTI_ENABLE_BLOG=true
NTI_ENABLE_CHROMIUM_SCRAPING=true

# Stock screener hard limits
NTI_MAX_PE=20.0
NTI_MAX_PB=3.0
NTI_MIN_MARKET_CAP_CR=500
NTI_PSU_BOOST_SCORE=10.0

# MTF risk display (informational only)
NTI_MTF_LEVERAGE=3.0
NTI_MTF_ANNUAL_INTEREST_RATE=0.12

# Blog settings
NTI_BLOG_WORD_TARGET_MID=500
NTI_BLOG_WORD_TARGET_FULL=900
NTI_BLOG_NEWS_HOURS=4

# LangGraph fusion settings
NTI_FUSION_MAX_CONCURRENT_LLM=5
NTI_FUSION_CRITIQUE_ROUNDS=1
NTI_FUSION_TIMEOUT_SECONDS=60

# === Optional ===
SENTRY_DSN=
